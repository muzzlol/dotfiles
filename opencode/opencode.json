{
  "$schema": "https://opencode.ai/config.json",
  "autoshare": false,
  "autoupdate": true,
  "mcp": {
    "exa": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "exa-mcp-server"
      ],
      "environment": {
        "EXA_API_KEY": "{env:EXA_API_KEY}"
      },
      "enabled": true
    }
  }
}